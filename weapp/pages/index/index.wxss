.status-bar{padding:16rpx 30rpx;font-size:26rpx;font-weight:500;border-radius:12rpx;margin-bottom:20rpx}.status-bar.trading{background:#e8f5e9;color:#27ae60}.status-bar.closed{background:#f5f5f5;color:#999}.index-row{display:flex;align-items:center;padding:12rpx 0;border-bottom:2rpx solid #f5f5f5}.index-row:last-child{border-bottom:none}.index-name{flex:1;font-size:28rpx;color:#333}.holding-row{display:flex;align-items:center;justify-content:space-between;padding:16rpx 0;border-bottom:2rpx solid #f5f5f5;cursor:pointer}.holding-row:active{background:#f9f9f9}.holding-info{display:flex;flex-direction:column}.holding-name{font-size:30rpx;font-weight:500;color:#333}.holding-code{font-size:22rpx;color:#999;margin-top:4rpx}.holding-price{text-align:right}.total-pnl{font-size:36rpx;font-weight:700;margin-bottom:16rpx;text-align:center;padding:20rpx;background:#fafafa;border-radius:12rpx}.tech-row{margin-bottom:20rpx;padding-bottom:16rpx;border-bottom:2rpx solid #f5f5f5}.tech-row:last-child{border-bottom:none;margin-bottom:0}.tech-header{display:flex;align-items:center;margin-bottom:8rpx}.tech-detail{display:flex;flex-direction:column;gap:6rpx;font-size:24rpx;color:#666;padding-left:8rpx}
