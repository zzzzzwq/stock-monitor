/** @format */.container{padding:20rpx 30rpx}.card{background:#fff;border-radius:16rpx;padding:24rpx;margin-bottom:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.06)}.card-title{font-size:28rpx;font-weight:600;color:#333;margin-bottom:16rpx}.price{font-weight:600;font-size:32rpx}.price.up{color:#e74c3c}.price.down{color:#27ae60}.price.neutral{color:#333}.tag{display:inline-block;padding:4rpx 12rpx;border-radius:8rpx;font-size:22rpx;margin-left:8rpx}.tag.up{background:#fce4e4;color:#e74c3c}.tag.down{background:#e8f5e9;color:#27ae60}.btn-primary{background:#1a1a2e;color:#fff;border-radius:12rpx;padding:24rpx;text-align:center;font-size:32rpx;width:100%;border:none}.btn-primary:active{opacity:.8}.input-group{margin-bottom:24rpx}.input-group label{display:block;font-size:26rpx;color:#666;margin-bottom:8rpx}.input-group input,.input-group picker{width:100%;padding:20rpx;border:2rpx solid #e0e0e0;border-radius:12rpx;font-size:30rpx;background:#fff;box-sizing:border-box}.empty-state{text-align:center;padding:80rpx 0;color:#999;font-size:28rpx}
